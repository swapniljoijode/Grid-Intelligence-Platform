# ─────────────────────────────────────────────────────────────────────────────
# Grid Intelligence Platform — environment template
# Copy this file to .env and fill in values. Never commit .env.
# Runtime secrets are fetched from Key Vault; .env is for local dev only.
# ─────────────────────────────────────────────────────────────────────────────

# Azure identity (service-principal for local dev; managed identity in Fabric)
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# Key Vault
KEY_VAULT_URI=https://<your-vault-name>.vault.azure.net/

# EIA Open Data API v2 — free key from https://www.eia.gov/opendata/
EIA_API_KEY=<your-eia-api-key>

# Microsoft Fabric Warehouse (ODBC)
FABRIC_SERVER=<workspace>.datawarehouse.fabric.microsoft.com
FABRIC_DATABASE=<warehouse-name>

# Event Hub / Eventstream
EVENTHUB_NAMESPACE=<namespace>.servicebus.windows.net
EVENTHUB_NAME=<eventhub-name>
EVENTHUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>

# Synthetic producer settings
PRODUCER_INTERVAL_SECONDS=5
GRID_REGION=ERCOT

# Airflow (portable variant — local only)
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=false
